{
  "name": "corpoturismo-logs-service",
  "version": "0.1.0",
  "private": true,
  "description": "Microservicio global de logs y tracking de mails (MongoDB).",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --enable-source-maps -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "dev:watch": "nodemon",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/main.js",
    "lint": "eslint .",
    "format": "prettier -w .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "mongodb": "^6.18.0",
    "morgan": "^1.10.0",
    "pino": "^9.8.0",
    "pino-pretty": "^13.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.3",
    "globals": "^16.5.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.9"
  }
}
